<Window x:Class="Task.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Task"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <TextBlock x:Name="Title" FontSize="24" HorizontalAlignment="Center" Margin="0,25,0,0" TextWrapping="Wrap" Text="Приложение для расчёта чаевых (калькулятор)" VerticalAlignment="Top"/>
        <Button x:Name="Calculate" Content="Рассчитать" HorizontalAlignment="Center" Margin="0,352,0,0" VerticalAlignment="Top" Height="46" Width="128" BorderThickness="3" Click="Calculate_Click"/>
        <TextBox x:Name="InputSum" HorizontalAlignment="Left" Margin="85,124,0,0" TextWrapping="Wrap" ToolTip="Введите сумму счёта:" VerticalAlignment="Top" Width="200" Height="30" BorderThickness="3" BorderBrush="Black" TextChanged="InputSum_TextChanged"/>
        <TextBox x:Name="InputGuests" HorizontalAlignment="Left" TextWrapping="Wrap" ToolTip="Введите количество гостей:" VerticalAlignment="Top" Width="200" Height="30" BorderThickness="3" BorderBrush="Black" Margin="85,233,0,0" TextChanged="InputGuests_TextChanged"/>

        <Grid Margin="494,162,64,186">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="25*"/>
                <ColumnDefinition Width="96*"/>

            </Grid.ColumnDefinitions>

            <RadioButton x:Name="TipsWithout" Content="Без чаевых" VerticalAlignment="Top" Grid.ColumnSpan="2" Checked="TipsWithout_Checked"/>
            <RadioButton x:Name="TipsFivePercentss" Content="5% чаевых" VerticalAlignment="Center" Grid.ColumnSpan="2" Grid.Row="1" Checked="TipsFivePercentss_Checked"/>
            <RadioButton x:Name="TipsTenPercents" Content="10% чаевых" VerticalAlignment="Center" Grid.ColumnSpan="2" Grid.Row="2" Checked="TipsTenPercents_Checked"/>
            <RadioButton x:Name="TipsFifteenPercents" Content="15% чаевых" VerticalAlignment="Center" Grid.ColumnSpan="2" Grid.Row="3" Checked="TipsFifteenPercents_Checked"/>
        </Grid>
        <TextBlock HorizontalAlignment="Left" Margin="510,334,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="105"><Run Text="Результат расчёта: общая сумма, чаевые, кол-во гостей"/><Run Language="ru-ru"/></TextBlock>
        <TextBox x:Name="Result"  HorizontalAlignment="Left" Margin="639,334,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="120" TextChanged="Result_TextChanged"/>
        <TextBox x:Name="Result2"  HorizontalAlignment="Left" Margin="639,380,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="120" TextChanged="Result_TextChanged"/>
        <TextBox x:Name="Result3"  HorizontalAlignment="Left" Margin="639,357,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="120" TextChanged="Result_TextChanged"/>
    </Grid>
</Window>
